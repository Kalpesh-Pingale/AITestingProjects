# Groq API key (required) — get yours at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use for answer generation (default: openai/gpt-oss-120b)
# GROQ_MODEL=openai/gpt-oss-120b

# Local embedding model (default: all-MiniLM-L6-v2)
# This runs locally via sentence-transformers — no API key needed
# Set to "nomic-ai/nomic-embed-text-v1.5" for Nomic Embed (~700MB download)
# EMBEDDING_MODEL=all-MiniLM-L6-v2
